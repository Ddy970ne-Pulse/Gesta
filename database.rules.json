{
  "rules": {

    "gesta_admins": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": false
      }
    },

    "userOrgIndex": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || root.child('gesta_admins').child(auth.uid).val() === true)"
      }
    },

    "orgs": {
      "$orgId": {

        "config": {
          ".read":  "auth != null && root.child('userOrgIndex').child(auth.uid).val() === $orgId",
          ".write": "auth != null && root.child('gesta_admins').child(auth.uid).val() === true"
        },

        "userProfiles": {
          ".read": "auth != null && root.child('userOrgIndex').child(auth.uid).val() === $orgId",
          "$uid": {
            ".write": "auth != null && root.child('userOrgIndex').child(auth.uid).val() === $orgId && (auth.uid === $uid || root.child('orgs').child($orgId).child('userProfiles').child(auth.uid).child('isAdmin').val() === true)"
          }
        },

        "tasks": {
          ".read": "auth != null && root.child('userOrgIndex').child(auth.uid).val() === $orgId",
          "$taskId": {
            ".write": "auth != null && root.child('userOrgIndex').child(auth.uid).val() === $orgId && ((!data.exists() && root.child('orgs').child($orgId).child('userProfiles').child(auth.uid).child('canAddTask').val() === true) || (data.exists() && newData.exists() && (root.child('orgs').child($orgId).child('userProfiles').child(auth.uid).child('canEdit').val() === true || data.child('createdBy').val() === auth.uid)) || (data.exists() && !newData.exists() && root.child('orgs').child($orgId).child('userProfiles').child(auth.uid).child('canDelete').val() === true))"
          }
        },

        "userTasks": {
          "$uid": {
            ".read":  "auth != null && auth.uid === $uid && root.child('userOrgIndex').child(auth.uid).val() === $orgId",
            ".write": "auth != null && auth.uid === $uid && root.child('userOrgIndex').child(auth.uid).val() === $orgId"
          }
        },

        "accessLogs": {
          ".write": "auth != null && root.child('userOrgIndex').child(auth.uid).val() === $orgId",
          ".read":  "auth != null && root.child('orgs').child($orgId).child('userProfiles').child(auth.uid).child('isAdmin').val() === true"
        }
      }
    },

    "superAdmin": {
      ".read":  "auth != null && root.child('gesta_admins').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('gesta_admins').child(auth.uid).val() === true",
      "invitations": {
        "$token": {
          ".read": true,
          ".write": "auth != null"
        }
      },
      "orgs": {
        "$orgId": {
          "name": { ".read": true }
        }
      }
    },

    "tasks":        { ".read": "auth != null", ".write": false },
    "userProfiles": { ".read": "auth != null", ".write": false },
    "userTasks":    { ".read": "auth != null", ".write": false },
    "accessLogs":   { ".read": false,          ".write": false },

    "$other": { ".read": false, ".write": false }
  }
}
