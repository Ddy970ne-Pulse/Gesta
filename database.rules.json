{
  "rules": {

    // ── Profils utilisateurs ──────────────────────────────────────────────────
    // Lecture : tout utilisateur connecté (pour la liste admin)
    // Écriture : l'utilisateur lui-même OU un administrateur (isAdmin = true)
    "userProfiles": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && (
          auth.uid === $uid ||
          root.child('userProfiles').child(auth.uid).child('isAdmin').val() === true
        )"
      }
    },

    // ── Tâches partagées ──────────────────────────────────────────────────────
    // Lecture : tout utilisateur connecté (filtre source géré côté client)
    // Création : utilisateurs avec canAddTask = true
    // Modification : utilisateurs avec canEdit = true, OU créateur de la tâche
    // Suppression : utilisateurs avec canDelete = true
    "tasks": {
      ".read": "auth != null",
      "$taskId": {
        ".write": "auth != null && (
          (
            !data.exists() &&
            root.child('userProfiles').child(auth.uid).child('canAddTask').val() === true
          ) ||
          (
            data.exists() &&
            newData.exists() &&
            (
              root.child('userProfiles').child(auth.uid).child('canEdit').val() === true ||
              data.child('createdBy').val() === auth.uid
            )
          ) ||
          (
            data.exists() &&
            !newData.exists() &&
            root.child('userProfiles').child(auth.uid).child('canDelete').val() === true
          )
        )"
      }
    },

    // ── Tâches personnelles ───────────────────────────────────────────────────
    // Lecture et écriture : uniquement le propriétaire (auth.uid === $uid)
    "userTasks": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ── Journaux d'accès ─────────────────────────────────────────────────────
    // Écriture : tout utilisateur connecté (log de connexion)
    // Lecture : administrateurs uniquement
    "accessLogs": {
      ".write": "auth != null",
      ".read":  "auth != null && root.child('userProfiles').child(auth.uid).child('isAdmin').val() === true"
    },

    // ── Tout autre nœud : refusé par défaut ──────────────────────────────────
    "$other": {
      ".read":  false,
      ".write": false
    }
  }
}
